<?xml version="1.0" encoding="utf-8"?>
<project>
    <meta title="DivaHx" package="" version="1.0.0" company="ZSolarDev" />
    <app main="Main" file="DivaHx" path="build/openfl" />
    <set name="BUILD_DIR" value="build/openfl" />
    <icon path="resources/logo/Logo50.png" size="50" />
    <icon path="resources/logo/Logo100.png" size="100" />
    <icon path="resources/logo/Logo500.png" size="500" />
    <icon path="resources/logo/Logo1k.png" size="1000" />
    <icon path="resources/logo/Logo30.png" size="3000" />

    <window background="#2c2f30" fps="120" />
    <window width="1280" height="720" min-width="1280" min-height="720" if="desktop" />
    <window width="0" height="0" if="html5" />

    <!-- classpath, haxe libs -->
    <source path="src" />
    <classpath name="src" />
    <assets path="resources" />

    <haxelib name="openfl" />
    <haxelib name="actuate" />
    <haxelib name="svg" />
    <haxelib name="hlwnative" />
    <haxelib name="hxfilemanager" />

    <haxelib name="haxeui-core" />
    <haxelib name="haxeui-openfl" />
</project>
