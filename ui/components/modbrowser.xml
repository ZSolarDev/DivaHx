<vbox width="100%" height="100%">
    <menubar text="Mod Browser" id="modBrowserTopMenu" percentWidth="100" style="padding: 5px; spacing: 5px;">
    </menubar>
    <frame text="Mods" id="modGridFrame" percentWidth="100" >
        <scrollview id="modGridScrollView" percentWidth="100" percentHeight="100" contentWidth="100%" style="padding: 5px; spacing: 5px;">
            <grid id="modGrid" columns="3" percentWidth="100" styleName="outline" horizontalAlign="center" style="padding: 5px; spacing: 10px;">
            </grid>
        </scrollview>
    </frame>
</vbox>