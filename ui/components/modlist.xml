<draggable-tableview width="500" height="500">
    <header width="100%">
        <column id="colEnabled" text="Enabled" width="70" />
        <column id="colName" text="Mod Name" width="100%" />
    </header>
    <item-renderer verticalAlign="center" horizontalAlign="center">
        <checkbox id="colEnabled" />
    </item-renderer>
    <item-renderer verticalAlign="center">
        <label id="colName" width="100%" />
    </item-renderer>
</draggable-tableview>